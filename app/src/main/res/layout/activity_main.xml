<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5FBEF"
    tools:context=".MainActivity">

    <LinearLayout
        android:id="@+id/mainLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Header -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="6dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:id="@+id/txtheader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="CANE CULTIVATION"
                android:gravity="center"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#1B5E20"
                android:padding="16dp"/>
        </com.google.android.material.card.MaterialCardView>

        <!-- Input Section -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="6dp"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Village -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Village Details"
                    android:textStyle="bold"
                    android:textColor="#2E7D32"
                    android:layout_marginBottom="6dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <EditText
                        android:id="@+id/edtvcodeval"
                        android:layout_width="70dp"
                        android:layout_height="45dp"
                        android:hint="VCode"
                        android:inputType="number"
                        android:background="@drawable/edittext_bg"
                        android:padding="8dp"/>

                    <EditText
                        android:id="@+id/edtvnameval"
                        android:layout_width="0dp"
                        android:layout_height="45dp"
                        android:layout_weight="1"
                        android:layout_marginStart="10dp"
                        android:hint="Village Name"
                        android:background="@drawable/edittext_bg"
                        android:padding="8dp"
                        android:focusable="false"/>
                </LinearLayout>

                <!-- Grower -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Grower Details"
                    android:textStyle="bold"
                    android:textColor="#2E7D32"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="6dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <EditText
                        android:id="@+id/edtGcodeval"
                        android:layout_width="70dp"
                        android:layout_height="45dp"
                        android:hint="GCode"
                        android:inputType="number"
                        android:background="@drawable/edittext_bg"
                        android:padding="8dp"/>

                    <EditText
                        android:id="@+id/edtgnameval"
                        android:layout_width="0dp"
                        android:layout_height="45dp"
                        android:layout_weight="1"
                        android:layout_marginStart="10dp"
                        android:hint="Grower Name"
                        android:background="@drawable/edittext_bg"
                        android:padding="8dp"
                        android:focusable="false"/>
                </LinearLayout>

                <!-- Button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnshowdata"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="SHOW DATA"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:layout_marginTop="16dp"
                    app:cornerRadius="12dp"
                    android:backgroundTint="#2E7D32"/>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Table Section -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="6dp">

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fillViewport="true">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Header Row -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:background="#A5D6A7"
                        android:padding="10dp">

                        <!-- FIXED ALL TEXTVIEWS -->
                        <TextView android:layout_width="120dp" android:layout_height="wrap_content" android:text="MachineNo"/>
                        <TextView android:layout_width="100dp" android:layout_height="wrap_content" android:text="VillageCode"/>
                        <TextView android:layout_width="100dp" android:layout_height="wrap_content" android:text="GrowerCode"/>
                        <TextView android:layout_width="120dp" android:layout_height="wrap_content" android:text="GrowerName"/>
                        <TextView android:layout_width="120dp" android:layout_height="wrap_content" android:text="FatherName"/>
                        <TextView android:layout_width="120dp" android:layout_height="wrap_content" android:text="VillageName"/>
                        <TextView android:layout_width="100dp" android:layout_height="wrap_content" android:text="SDate"/>
                        <TextView android:layout_width="100dp" android:layout_height="wrap_content" android:text="Variety"/>
                        <TextView android:layout_width="100dp" android:layout_height="wrap_content" android:text="CaneType"/>
                        <TextView android:layout_width="100dp" android:layout_height="wrap_content" android:text="PlotNo"/>
                        <TextView android:layout_width="100dp" android:layout_height="wrap_content" android:text="Katha"/>
                    </LinearLayout>

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/recyclerView"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                </LinearLayout>

            </HorizontalScrollView>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</ScrollView>